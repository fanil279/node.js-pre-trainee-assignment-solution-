{
    "compilerOptions": {
        "target": "ES2021",
        "module": "Node16",
        "moduleResolution": "Node16",
        "isolatedModules": true,

        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,

        "types": ["node", "jest"],

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,

        "skipLibCheck": true
    }
}
